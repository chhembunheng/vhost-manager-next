#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET="/usr/local/bin/vhost-manager-agent"

if [[ "${EUID}" -ne 0 ]]; then
    echo "Run with sudo: sudo ${APP_DIR}/bin/install-agent-command" >&2
    exit 1
fi

cat > "${TARGET}" <<AGENT
#!/usr/bin/env bash
set -euo pipefail

APP_DIR="\${VHOST_MANAGER_HOME:-${APP_DIR}}"
cd "\${APP_DIR}"

exec node agent/server.mjs "\$@"
AGENT

chown root:root "${TARGET}"
chmod 755 "${TARGET}"
echo "Installed ${TARGET}"
