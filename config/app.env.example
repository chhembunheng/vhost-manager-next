# Copy to config/app.env.local and edit per teammate/machine.
# Keep values simple: no spaces, no shell commands.
VHOST_MANAGER_DOMAIN=vhost-manager.local
VHOST_BASE_DIR=/home/YOUR_USER/www
VHOST_ALLOWED_BASE_DIRS=/home/YOUR_USER/www
VHOST_OWNER=YOUR_USER
VHOST_GROUP=www-data
VHOST_WEB_USER=www-data
VHOST_APP_USERS=YOUR_USER
VHOST_HOST_IP=127.0.0.1
VHOST_NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
VHOST_NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
VHOST_ALLOWED_CLIENTS=127.0.0.1,192.168.1.0/24
VHOST_ALLOWED_PHP_VERSIONS=8.5,8.3,8.2,8.1,8.0,7.4,5.6
